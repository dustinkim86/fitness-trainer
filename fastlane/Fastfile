default_platform(:ios)

platform :ios do

  desc "앱스토어용 빌드 + TestFlight 업로드"
  lane :beta do
    setup_ci if ENV['CI']

    # App Store Connect API Key 사용 (2FA 불필요)
    api_key = app_store_connect_api_key(
      key_id:        ENV["ASC_KEY_ID"],
      issuer_id:     ENV["ASC_ISSUER_ID"],
      key_content:   ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    # 인증서 + 프로비저닝 프로파일 가져오기
    match(
      type: "appstore",
      app_identifier: "com.junho.fitness",
      api_key: api_key,
      readonly: true
    )

    # 빌드 번호 자동 증가
    increment_build_number(
      xcodeproj: "ios/App/App.xcodeproj"
    )

    # 빌드
    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      configuration: "Release"
    )

    # TestFlight 업로드
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "앱스토어 정식 제출"
  lane :release do
    setup_ci if ENV['CI']

    api_key = app_store_connect_api_key(
      key_id:        ENV["ASC_KEY_ID"],
      issuer_id:     ENV["ASC_ISSUER_ID"],
      key_content:   ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: false
    )

    match(
      type: "appstore",
      app_identifier: "com.junho.fitness",
      api_key: api_key,
      readonly: true
    )

    increment_build_number(xcodeproj: "ios/App/App.xcodeproj")

    build_app(
      workspace: "ios/App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      configuration: "Release"
    )

    upload_to_app_store(
      api_key: api_key,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      skip_screenshots: true,
      skip_metadata: true
    )
  end

  error do |lane, exception|
    UI.error("Lane #{lane} failed: #{exception.message}")
  end

end
